#include <iostream>
using namespace std;

int comparisons = 0;
int swaps = 0;

// Swap function
void swapValues(int &a, int &b) {
    swaps++;
    int temp = a;
    a = b;
    b = temp;
}

// Bitonic Merge
void bitonicMerge(int arr[], int low, int count, bool descending) {
    if (count > 1) {
        int k = count / 2;
        for (int i = low; i < low + k; i++) {
            comparisons++;
            if (descending == (arr[i] < arr[i + k])) {
                swapValues(arr[i], arr[i + k]);
            }
        }
        bitonicMerge(arr, low, k, descending);
        bitonicMerge(arr, low + k, k, descending);
    }
}

// Bitonic Sort
void bitonicSort(int arr[], int low, int count, bool descending) {
    if (count > 1) {
        int k = count / 2;

        bitonicSort(arr, low, k, true);   // first half ascending
        bitonicSort(arr, low + k, k, false); // second half descending

        bitonicMerge(arr, low, count, descending);
    }
}

// Print array
void printArray(int arr[], int size) {
    for (int i = 0; i < size; i++)
        cout << arr[i] << " ";
    cout << endl;
}

int main() {
    int n;

    cout << "Enter number of elements (power of 2 preferred): ";
    cin >> n;

    int *arr = new int[n];

    cout << "Enter elements:\n";
    for (int i = 0; i < n; i++)
        cin >> arr[i];

    bitonicSort(arr, 0, n, false); // DESCENDING

    cout << "\nSorted array (Descending):\n";
    printArray(arr, n);

    cout << "\nTotal Comparisons: " << comparisons << endl;
    cout << "Total Swaps: " << swaps << endl;

    delete[] arr;
    return 0;
}
